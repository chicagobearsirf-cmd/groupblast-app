# Copy to .env and fill in for cloud/hybrid mode. Local mode needs none of these.

# ---- Whitelabel brand (all optional; defaults to "Command Center") ----
# Set these per copy to rebrand the app — no code changes needed.
VITE_BRAND_NAME=
VITE_BRAND_SHORT_NAME=
VITE_BRAND_TAGLINE=
# Logo: drop the image in public/ and point here, e.g. /groupblast-logo.png
VITE_BRAND_LOGO_URL=/groupblast-icon.png
# Accent hex (reserved for theming), e.g. #2563EB
VITE_BRAND_ACCENT=

# App mode: local | cloud | hybrid  (default: local)
#   local  = current SQLite + Playwright local API, no cloud
#   cloud  = Supabase data only, NO Facebook automation (hosted dashboard)
#   hybrid = cloud dashboard + local agent/extension for automation
VITE_APP_MODE=local

# Supabase (public — safe to expose to the browser). Required for cloud/hybrid.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Local API / desktop runtime overrides (optional).
API_PORT=3001
GROUPBLAST_DATA_DIR=
VITE_CACHE_DIR=
